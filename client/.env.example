# Variables de entorno del CLIENTE (frontend)
# IMPORTANTE: Solo variables con prefijo VITE_ son accesibles desde el código React

# URL del proyecto Supabase (se obtiene en: Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon/pública de Supabase (segura para el frontend)
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
