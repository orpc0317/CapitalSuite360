# Variables de entorno del SERVIDOR (backend)
# NUNCA subir este archivo a GitHub

# Puerto del servidor Express
PORT=4000

# URL del frontend (para configurar CORS)
CLIENT_URL=http://localhost:5173

# Credenciales de Supabase
# Obtener en: Supabase Dashboard > Settings > API
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon (para verificar tokens de usuarios)
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Service Role Key — SOLO para el servidor, con acceso completo a la BD
# NUNCA exponer esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
